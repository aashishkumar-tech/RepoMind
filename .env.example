# ── RepoMind Environment Variables ──
# Copy this to .env and fill in your values

# AWS
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=
S3_SAM_BUCKET=repomind-sam-deployments
S3_DATA_BUCKET=repomind-data

# GitHub App
GITHUB_APP_ID=
GITHUB_INSTALLATION_ID=
GITHUB_PRIVATE_KEY_PATH=private-key.pem
GITHUB_WEBHOOK_SECRET=

# Groq LLM
GROQ_API_KEY=

# OpenAI Embeddings
OPENAI_API_KEY=

# Email Notifications
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
NOTIFICATION_EMAILS=

# Target Repo (for testing)
TARGET_REPO=

# Test Run ID (GitHub Actions failed run ID for local testing)
# Find it at: https://github.com/<owner>/<repo>/actions → click a failed run → copy the number from the URL
TEST_RUN_ID=

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Application
LOG_LEVEL=INFO
ENVIRONMENT=development
